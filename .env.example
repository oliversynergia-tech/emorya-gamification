APP_URL=http://localhost:3000
# Use https://... for production.
NODE_ENV=development

# PostgreSQL connection for app data, leaderboards, quests, and admin state.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/emorya

# Session signing secret for email/password auth and account linking flows.
SESSION_SECRET=replace-with-a-long-random-string

# Email/password auth provider settings.
AUTH_EMAIL_FROM=noreply@emorya.com

# MultiversX wallet integration.
NEXT_PUBLIC_MULTIVERSX_CHAIN=mainnet
NEXT_PUBLIC_MULTIVERSX_WALLETCONNECT_PROJECT_ID=

# Optional backend integrations.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MULTIVERSX_API_URL=https://api.multiversx.com
CRON_SNAPSHOTS_ENABLED=false
LEADERBOARD_SNAPSHOT_OWNER=manual
CAMPAIGN_PACK_REPORT_OWNER=external
PAYOUT_AUTOMATION_OWNER=manual
AUTOMATION_ACTOR_USER_ID=
PAYOUT_AUTOMATION_MAX_RETRIES=3
MODERATION_ALERT_STALE_MINUTES=1440
MODERATION_ALERT_OLDEST_WARNING_MINUTES=360
MODERATION_ALERT_BACKLOG_WARNING_COUNT=8
MODERATION_ALERT_BACKLOG_CRITICAL_COUNT=15
MODERATION_ALERT_AVERAGE_WARNING_MINUTES=90
MODERATION_ALERT_INBOX_ENABLED=true
MODERATION_ALERT_WEBHOOK_URL=
MODERATION_ALERT_EMAIL_TO=
MODERATION_ALERT_SLACK_WEBHOOK_URL=
MODERATION_ALERT_DISCORD_WEBHOOK_URL=
CAMPAIGN_PACK_REPORTS_ENABLED=true
CAMPAIGN_PACK_REPORT_OUTPUT_DIR=reports/campaign-packs
TWITTER_API_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

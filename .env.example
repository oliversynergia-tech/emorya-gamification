APP_URL=http://localhost:3000
NODE_ENV=development

# PostgreSQL connection for app data, leaderboards, quests, and admin state.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/emorya

# Session signing secret for email/password auth and account linking flows.
SESSION_SECRET=replace-with-a-long-random-string

# Email/password auth provider settings.
AUTH_EMAIL_FROM=noreply@emorya.com

# MultiversX wallet integration.
NEXT_PUBLIC_MULTIVERSX_CHAIN=mainnet
NEXT_PUBLIC_MULTIVERSX_WALLETCONNECT_PROJECT_ID=

# Optional backend/admin integrations.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MULTIVERSX_API_URL=https://api.multiversx.com
TWITTER_API_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

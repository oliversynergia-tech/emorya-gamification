{
  "name": "emorya-gamification",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:setup": "node scripts/dev.mjs migrate && node scripts/dev.mjs seed",
    "dev:reset": "node scripts/dev.mjs reset",
    "dev:db:doctor": "node scripts/dev.mjs doctor",
    "dev:db:migrate": "node scripts/dev.mjs migrate",
    "dev:db:migrate:status": "node scripts/dev.mjs migrate-status",
    "dev:db:seed": "node scripts/dev.mjs seed",
    "dev:db:validate:quests": "node scripts/dev.mjs validate-quests",
    "dev:db:snapshot:all-time": "node scripts/dev.mjs snapshot all-time",
    "dev:db:snapshot:referral": "node scripts/dev.mjs snapshot referral",
    "dev:db:snapshot:weekly": "node scripts/dev.mjs snapshot weekly",
    "dev:db:snapshot:monthly": "node scripts/dev.mjs snapshot monthly",
    "dev:db:snapshot:scheduled": "node scripts/dev.mjs snapshot-scheduled",
    "ops:db:migrate": "node scripts/ops.mjs migrate",
    "ops:db:migrate:status": "node scripts/ops.mjs migrate-status",
    "ops:db:validate:quests": "node scripts/ops.mjs validate-quests",
    "ops:db:snapshot:scheduled": "node scripts/ops.mjs snapshot-scheduled",
    "dev:campaign-packs:report": "node scripts/export-campaign-pack-report.mjs",
    "ops:campaign-packs:report": "node scripts/export-campaign-pack-report.mjs",
    "ops:payouts:process": "node scripts/process-token-payouts.mjs",
    "ops:env:check": "node scripts/env-check.mjs",
    "ops:release:state-check": "node scripts/release-state-check.mjs",
    "ops:release:gate": "npm run ops:env:check && npm run ops:db:migrate && npm run ops:db:migrate:status && npm run ops:db:validate:quests && npm run ops:release:state-check",
    "dev:boot": "npm run dev:setup && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --experimental-strip-types --test tests/*.test.ts"
  },
  "dependencies": {
    "@multiversx/sdk-core": "^15.4.0",
    "@multiversx/sdk-wallet-connect-provider": "^6.1.4",
    "@types/pg": "^8.18.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^24.7.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.1.6",
    "typescript": "^5.9.3"
  }
}
